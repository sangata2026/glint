# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# wallet secrets — NEVER commit
*.keystore
*.key
wallet.json
secrets/

# local JSON store (creator profiles, dev only)
.data/

# rust / soroban build artifacts
contracts/**/target/
contracts/**/Cargo.lock

# soroban test snapshots — auto-generated by `cargo test`, not source
contracts/**/test_snapshots/

# typescript
*.tsbuildinfo
next-env.d.ts
